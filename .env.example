# scrape-stream-api environment configuration.
# Copy this file to `.env` and adjust as needed:  cp .env.example .env

# Port the HTTP server listens on (inside the container).
# The docker-compose.yml publishes this port to the host.
PORT=5005

# Path to a Chrome binary. Leave EMPTY to use the Chromium that Playwright
# downloads during the Docker build. Inside the container this should always
# be empty — the Dockerfile already installs a known-good Chromium.
CHROME_PATH=

# Directory Chrome uses for its persistent profile (cookies, cache).
# In Docker this is overridden to `/app/user_data` (a named volume), so the
# value here only affects local `bun run dev` runs.
USER_DATA_DIR=./user_data

# Per-page navigation/scrape timeout, in milliseconds.
SCRAPER_TIMEOUT=15000

# Optional: override the host-side port if you want host:container mapping
# to differ (e.g. publish on host port 80 -> container port 5005).
# Used only by docker-compose.yml, not by the app itself.
# HOST_PORT=80
