# Server configuration
PORT=5005

# Path to a real Chrome binary. Leave empty to use Playwright's bundled Chromium.
CHROME_PATH=

# Directory to persist browser user profile/cookies
USER_DATA_DIR=./user_data

# Scraper timeout in milliseconds (default: 15 seconds)
SCRAPER_TIMEOUT=15000

# Proxy mode upstream timeout in milliseconds (default: 30 seconds)
PROXY_UPSTREAM_TIMEOUT_MS=30000
